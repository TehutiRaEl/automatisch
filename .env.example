# Sovereign Hive - automatisch colony environment configuration
# Copy this file to .env and fill in your values before running:
#   docker compose -f ../THEHIVE/docker-compose.federation.yml up -d
#
# These are read by docker/entrypoint.sh (via the backend's yarn db:migrate /
# yarn start) and by docker-compose.federation.yml's automatisch service.

# ============================================
# REQUIRED — automatisch core secrets
# ============================================
# 32-byte (or longer) random string, e.g.: openssl rand -hex 16
ENCRYPTION_KEY=
# Random secret used to sign sessions/cookies
APP_SECRET_KEY=
# Random secret used to verify inbound webhook signatures
WEBHOOK_SECRET_KEY=

# ============================================
# DATABASE (provisioned by docker-compose.federation.yml)
# ============================================
# Password for the automatisch_db Postgres service; matches
# AUTOMATISCH_DB_PASSWORD in docker-compose.federation.yml
AUTOMATISCH_DB_PASSWORD=hivepass

# ============================================
# HIVE INTEGRATION
# ============================================
QUEEN_URL=http://thehive:8080
